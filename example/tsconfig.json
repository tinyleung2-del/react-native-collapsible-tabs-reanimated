{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "react-native-collapsible-tabs-reanimated": ["../src/index.ts"],
      "react-native-collapsible-tabs-reanimated/flash-list": [
        "../src/flash-list.ts"
      ],
      "react-native-collapsible-tabs-reanimated/legend-list": [
        "../src/legend-list.ts"
      ],
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
