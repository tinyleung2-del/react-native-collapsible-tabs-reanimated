{
  "name": "react-native-collapsible-tabs-reanimated",
  "version": "0.1.0-beta",
  "description": "Collapsible tab views for React Native powered by Reanimated and Gesture Handler.",
  "source": "src/index.ts",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "files": [
    "src",
    "lib",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "example"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf lib"
  },
  "keywords": [
    "react-native",
    "collapsible",
    "tabs",
    "reanimated",
    "gesture-handler",
    "pager-view"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leungwensen/react-native-collapsible-tabs-reanimated.git"
  },
  "author": "leungtinyau27m5 (https://github.com/leungtinyau27m5)",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-pager-view": ">=6.0.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-worklets": ">=0.6.0"
  },
  "devDependencies": {
    "@babel/core": "latest",
    "@react-native/babel-preset": "latest",
    "@react-native/metro-config": "latest",
    "@react-native/typescript-config": "latest",
    "@types/react": "latest",
    "react": "latest",
    "react-native": "latest",
    "react-native-builder-bob": "latest",
    "react-native-gesture-handler": "latest",
    "react-native-pager-view": "latest",
    "react-native-reanimated": "latest",
    "react-native-worklets": "latest",
    "rimraf": "latest",
    "typescript": "latest"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "packageManager": "yarn@4.16.0+sha512.5374c94eb4ef6aa8188fb112f20c1aa6569f248d676c5e576e1fd2a1a4d8d87a96df65d9dfe1c2a0252cbe38bda46cf18d955005b81b43cc7607a5c9d56fd2b6"
}
